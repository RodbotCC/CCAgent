      "defined_in": "components.jsx",
      "items_shape": "[{ label, icon, onClick, danger, disabled, shortcut, divider, keepOpen }]",
      "wired_on": ["legacy grid CellContextMenu", "leads", "clients", "coworkers", "contacts", "venues", "intake cards", "delegations cards + rows", "boxes list + html demos"],
      "pattern": "useContextMenu() + onContextMenu={...} + menu.render(buildItemsFor(target), title)"
    },
