    "browser_computer_handoffs": {
      "POST /api/computer_use/handoff": ["grid ChatRail"],
      "POST /api/browser_use/handoff": ["grid ChatRail"],
      "GET /api/browser_use/jobs/<id>": ["grid ChatRail"],
      "POST /api/browser_open/handoff": ["grid ChatRail"]
