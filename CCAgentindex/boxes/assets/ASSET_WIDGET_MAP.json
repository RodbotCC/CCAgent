  "api_to_page_mapping": {
    "universal_health": {"/api/status": ["every page", "grid ChatRail command cockpit"]},
    "box_graph": {"GET /api/box_graph": ["box_graph", "grid ChatRail launcher", "Topbar box graph chip"]},
    "boxes_domain": {
      "GET /api/boxes/list": ["boxes"],
      "GET /api/boxes/<id>": ["boxes", "intake Box Report synthesis"],
      "GET /api/boxes/<id>/html": ["boxes"],
      "GET /api/boxes/<id>/template/<slug>": ["boxes"]
    },
    "reports_intake": {
      "GET /api/reports/list": ["intake"],
      "GET /api/reports/get?slug=<id>": ["intake Box Report or Workspace"],
      "POST /api/reports/ask": ["intake"],
      "POST /api/reports/ingest": ["intake"]
    },
    "people_venues": {"GET /api/people/list": ["leads", "clients", "coworkers", "contacts"], "GET /api/venues/list": ["venues"]},
