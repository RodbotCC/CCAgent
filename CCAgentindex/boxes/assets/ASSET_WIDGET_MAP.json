    {"if_you_change": "connectors.js channel catalog", "recheck": ["delegations", "grid (ChatRail)", "intake", "boxes"]},
    {"if_you_change": "mission_control_loader.js", "recheck": ["every page that reads MissionControl.* (effectively all)"]},
    {"if_you_change": "ai_instructions.js system-prompt assembly", "recheck": ["grid ChatRail", "intake ask"]},
    {"if_you_change": "any new /api/* endpoint", "recheck": ["the page that calls it", "sitemap entry", "CONNECTIONS.md if external"]},
    {"if_you_change": "lucide.js icons", "recheck": ["every page (bump cache-buster)"]},
    {"if_you_change": "styles.css", "recheck": ["every page (bump cache-buster)"]},
    {"if_you_change": "any JS/CSS file", "rule": "every JS/CSS edit must bump its ?v= in Secretary.html (DEC-2026-04-29-007)"}
  ],
