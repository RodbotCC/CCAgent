%% Source-of-Truth Ledger — decision tree for "which file should I trust first?"
%% Walk the universal trust ordering, then resolve at the per-domain table.
%% Reference: SOURCE_OF_TRUTH.md §2 + §3.

flowchart TD
  Start([Question about a fact, file, or system state]) --> Domain{What domain<br/>is this about?}

  Domain -->|Client truth<br/>plans · comms · decisions| ClientPath
  Domain -->|Page / UI<br/>routes · assets · bindings| PagePath
  Domain -->|Project state<br/>"what's true now"| StatePath
  Domain -->|Settled rules<br/>"is this still policy?"| RulesPath
  Domain -->|External system<br/>Close · Pieces · Twilio · etc.| ExtPath

  subgraph ClientPath ["§3.1 Client Truth"]
    direction TB
    C1[Close.com API] --> C2[01b_comms_verbatim.md]
    C2 --> C3[comms/&lt;type&gt;_&lt;date&gt;_&lt;id&gt;.json]
    C3 --> C4[01_comms.md]
    C4 --> C5[00_meta.json]
    C5 --> C6[client_ledger.md]
    C6 --> C7[audit_marker.md]
    C7 --> C8[04_profile.md / *_enrichment.md<br/>INTERNAL ONLY]
    C8 --> C9[05_seven_day_plan.md<br/>STRATEGY DRAFT — never truth]
  end

  subgraph PagePath ["§3.2 Page / UI Truth"]
    direction TB
    P1[screens.jsx / app.jsx / *.js source] --> P2[page_asset_sitemap.md<br/>UI Done Gate]
    P2 --> P3[LEDGERS/PAGES/&lt;route&gt;.md<br/>· planned ·]
    P3 --> P4[LEDGERS/WIDGETS/&lt;widget&gt;.md<br/>· planned ·]
  end

  subgraph StatePath ["§3.3 Project State Truth"]
    direction TB
    S1[GitHub main] --> S2[local working copy]
    S2 --> S3[GLOBAL_LEDGER §2]
    S3 --> S4[TEMPORAL_CONTINUITY §1]
    S4 --> S5[git log / activity.jsonl]
  end

  subgraph RulesPath ["§3.4 Settled Rules Truth"]
    direction TB
    R1[DECISIONS_LEDGER active] --> R2[DECISIONS_LEDGER under-review]
    R2 --> R3[COMMUNICATIONS promoted]
    R3 --> R4[COMMUNICATIONS active]
  end

  subgraph ExtPath ["§3.5 External System Truth"]
    direction TB
    E1[Service API/UI] --> E2[local mirror in file tree]
    E2 --> E3[generated views/reports]
  end

  ClientPath --> Conflict{Two sources<br/>disagree?}
  PagePath --> Conflict
  StatePath --> Conflict
  RulesPath --> Conflict
  ExtPath --> Conflict

  Conflict -->|No| Trust([Trust the highest-ranked<br/>source you found])
  Conflict -->|Yes| Walk[Walk the universal ordering §2<br/>higher rank wins]
  Walk --> Resolved{Resolved?}
  Resolved -->|Yes| Trust
  Resolved -->|No, equal rank| Recent[Prefer more recent]
  Recent --> Resolved2{Resolved?}
  Resolved2 -->|Yes| Trust
  Resolved2 -->|No, equal date| Closer[Prefer closer to system of record]
  Closer --> Resolved3{Resolved?}
  Resolved3 -->|Yes| Trust
  Resolved3 -->|No| Log[Log to OPEN_PROBLEMS_LEDGER<br/>+ escalate to Jake<br/>OR proceed with safer view]
  Log --> Trust

  classDef ranked fill:#dcefff,stroke:#2a5a8a,stroke-width:1px;
  classDef internal fill:#fff7d6,stroke:#b08a00,stroke-width:1px;
  classDef warn fill:#ffe9e9,stroke:#a33,stroke-width:1px;
  classDef gate fill:#fff7d6,stroke:#b08a00,stroke-width:1px;
  classDef terminal fill:#dcffd6,stroke:#2a8a2a,stroke-width:2px;
  classDef start fill:#f0f0f0,stroke:#666,stroke-width:2px;

  class C1,C2,C3,C4,C5,C6,C7,P1,P2,P3,P4,S1,S2,S3,S4,S5,R1,R2,R3,R4,E1,E2,E3 ranked;
  class C8 internal;
  class C9 warn;
  class Domain,Conflict,Resolved,Resolved2,Resolved3 gate;
  class Walk,Recent,Closer,Log ranked;
  class Trust terminal;
  class Start start;
