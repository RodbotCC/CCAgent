    GL --> JSON["GLOBAL_LEDGER.json<br/>(structured mirror)"]:::active
    GL --> IDX["INDEX.md<br/>(roster)"]:::active

    GL --> SOT["Source-of-Truth Ledger"]:::planned
    GL --> DOD["Definition of Done Ledger"]:::planned
    GL --> TC["Temporal Continuity Ledger"]:::planned
    GL --> NS["North Star Ledger"]:::planned
    GL --> PH["Phase Ledger"]:::planned

    GL --> DIR["Directory Ledger"]:::planned
    GL --> FC["File Contents Ledger"]:::planned
    GL --> AWM["Asset / Widget Map"]:::planned
    GL --> CONN["Connections Ledger"]:::planned
    GL --> SET["Settings Ledger"]:::planned

    GL --> DEC["Decisions Ledger"]:::planned
    GL --> COMM["Communications Ledger<br/>(LEDGERS/COMMUNICATIONS_LEDGER.md)"]:::active
    GL --> OP["Open Problems Ledger"]:::planned
    GL --> AUD["Audit Ledger<br/>(out-of-scope 2026-04-29)"]:::outofscope
