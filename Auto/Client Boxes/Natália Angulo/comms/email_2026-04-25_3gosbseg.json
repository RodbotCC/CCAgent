\" style=\"margin-bottom:28px;\">\n        <tr>\n          <td bgcolor=\"#ff4b00\" style=\"background-color:#ff4b00;border-radius:5px;padding:11px 22px;\">\n            <a href=\"https://rawdre.github.io/comeketo-menu-landing/#packages\" style=\"color:#ffffff;font-size:14px;font-weight:bold;text-decoration:none;font-family:Arial,Helvetica,sans-serif;\">🔥 Explore the Full Menu Calculator</a>\n          </td>\n        </tr>\n      </table>\n\n      <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"margin-bottom:20px;border:1px solid #e8e8e8;border-radius:8px;overflow:hidden;\">\n        <tr>\n          <td bgcolor=\"#1a1a1a\" style=\"background-color:#1a1a1a;padding:13px 20px;\">\n            <p style=\"margin:0;font-size:14px;font-weight:bold;color:#ffffff;font-family:Arial,Helvetica,sans-serif;\">🔥 Option 1 — Brazilian BBQ (Churrasco)</p>\n          </td>\n        </tr>\n        <tr>\n          <td bgcolor=\"#f9f9f9\" style=\"background-color:#f9f9f9;padding:9px 20px;border-bottom:1px solid #e8e8e8;\">\n            <p style=\"margin:0;font-size:13px;color:#666666;font-family:Arial,Helvetica,sans-serif;\">On-site grilling with our team — the real deal!  |  A balanced full-service spread with our core Brazilian barbecue favorites.</p>\n          </td>\n        </tr>\n        <tr>\n          <td style=\"padding:16px 20px;\">\n            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n              <tr>\n                <td style=\"padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:14px;font-family:Arial,Helvetica,sans-serif;color:#333333;\">Food ($17.99 × 100 guests)</td>\n                <td align=\"right\" style=\"padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:14px;font-family:Arial,Helvetica,sans-serif;color:#333333;font-weight:500;\">$1799.00</td>\n              </tr>\n              <tr>\n                <td style=\"padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:14px;font-family:Arial,Helvetica,sans-serif;color:#333333;\">Appetizers</td>\n                <td align=\"right\" style=\"padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:14px;font-family:Arial,Helvetica,sans-serif;color:#333333;font-weight:500;\">$0.00</td>\n              </tr>\n              <tr>\n                <td style=\"padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:14px;font-family:Arial,Helvetica,sans-serif;color:#333333;\">MA Tax (7%)</td>\n                <td align=\"right\" style=\"padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:14px;font-family:Arial,Helvetica,sans-serif;color:#333333;font-weight:500;\">$125.93</td>\n              </tr>\n              <tr>\n                <td style=\"padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:14px;font-family:Arial,Helvetica,sans-serif;color:#333333;\">Service, Fuel &amp; Admin (24%)</td>\n                <td align=\"right\" style=\"padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:14px;font-family:Arial,Helvetica,sans-serif;color:#333333;font-weight:500;\">$431.76</td>\n              </tr>\n              <tr>\n                <td style=\"padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:14px;font-family:Arial,Helvetica,sans-serif;color:#333333;\">Service Charge (over 50 guests at $3/pp)</td>\n                <td align=\"right\" style=\"padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:14px;font-family:Arial,Helvetica,sans-serif;color:#333333;font-weight:500;\">$300.00</td>\n              </tr>\n              <tr>\n                <td style=\"padding:12px 0 6px;font-size:15px;font-weight:bold;font-family:Arial,Helvetica,sans-serif;color:#1a1a1a;\">Ballpark Total</td>\n                <td align=\"right\" style=\"padding:12px 0 6px;font-size:15px;font-weight:bold;font-family:Arial,Helvetica,sans-serif;color:#1a1a1a;\">~$2656.69</td>\n              </tr>\n            </table>\n          </td>\n        </tr>\n      </table>\n\n      <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"margin-bottom:24px;border:1px solid #e8e8e8;border-radius:8px;overflow:hidden;\">\n        <tr>\n          <td bgcolor=\"#1a1a1a\" style=\"background-color:#1a1a1a;padding:13px 20px;\">\n            <p style=\"margin:0;font-size:14px;font-weight:bold;color:#ffffff;font-family:Arial,Helvetica,sans-serif;\">🍽️ Option 2 — Deluxe Churrasco</p>\n          </td>\n        </tr>\n        <tr>\n          <td bgcolor=\"#f9f9f9\" style=\"background-color:#f9f9f9;padding:9px 20px;border-bottom:1px solid #e8e8e8;\">\n            <p style=\"margin:0;font-size:13px;color:#666666;font-family:Arial,Helvetica,sans-serif;\">One extra protein, fuller spread  |  A stronger step up if you want a fuller wedding spread with more room to impress guests.</p>\n          </td>\n        </tr>\n        <tr>\n          <td style=\"padding:16px 20px;\">\n            <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n              <tr>\n                <td style=\"padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:14px;font-family:Arial,Helvetica,sans-serif;color:#333333;\">Food ($20.99 × 100 guests)</td>\n                <td align=\"right\" style=\"padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:14px;font-family:Arial,Helvetica,sans-serif;color:#333333;font-weight:500;\">$2099.00</td>\n              </tr>\n              <tr>\n                <td style=\"padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:14px;font-family:Arial,Helvetica,sans-serif;color:#333333;\">Appetizers</td>\n                <td align=\"right\" style=\"padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:14px;font-family:Arial,Helvetica,sans-serif;color:#333333;font-weight:500;\">$0.00</td>\n              </tr>\n              <tr>\n                <td style=\"padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:14px;font-family:Arial,Helvetica,sans-serif;color:#333333;\">MA Tax (7%)</td>\n                <td align=\"right\" style=\"padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:14px;font-family:Arial,Helvetica,sans-serif;color:#333333;font-weight:500;\">$146.93</td>\n              </tr>\n              <tr>\n                <td style=\"padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:14px;font-family:Arial,Helvetica,sans-serif;color:#333333;\">Service, Fuel &amp; Admin (24%)</td>\n                <td align=\"right\" style=\"padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:14px;font-family:Arial,Helvetica,sans-serif;color:#333333;font-weight:500;\">$503.76</td>\n              </tr>\n              <tr>\n                <td style=\"padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:14px;font-family:Arial,Helvetica,sans-serif;color:#333333;\">Service Charge (over 50 guests at $3/pp)</td>\n                <td align=\"right\" style=\"padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:14px;font-family:Arial,Helvetica,sans-serif;color:#333333;font-weight:500;\">$300.00</td>\n              </tr>\n              <tr>\n                <td style=\"padding:12px 0 6px;font-size:15px;font-weight:bold;font-family:Arial,Helvetica,sans-serif;color:#1a1a1a;\">Ballpark Total</td>\n                <td align=\"right\" style=\"padding:12px 0 6px;font-size:15px;font-weight:bold;font-family:Arial,Helvetica,sans-serif;color:#1a1a1a;\">~$3049.69</td>\n              </tr>\n            </table>\n          </td>\n        </tr>\n      </table>\n\n      <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"margin-bottom:22px;\">\n        <tr>\n          <td bgcolor=\"#fff8f0\" style=\"background-color:#fff8f0;border:1px solid #ffe0c0;border-radius:8px;padding:16px 20px;\">\n            <p style=\"margin:0 0 8px;font-size:14px;font-weight:bold;color:#cc4400;font-family:Arial,Helvetica,sans-serif;\">🌟 Make It Your Own!</p>\n            <p style=\"margin:0 0 4px;font-size:14px;color:#555555;font-family:Arial,Helvetica,sans-serif;\">🧀 Appetizers — available to add on</p>\n            <p style=\"margin:0 0 4px;font-size:14px;color:#555555;font-family:Arial,Helvetica,sans-serif;\">🍰 Desserts — available to add on</p>\n            <p style=\"margin:0;font-size:14px;color:#555555;font-family:Arial,Helvetica,sans-serif;\">🥩 Extra proteins and sides — available to customize</p>\n          </td>\n        </tr>\n      </table>\n\n      <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"margin-bottom:22px;\">\n        <tr>\n          <td bgcolor=\"#f9f9f9\" style=\"background-color:#f9f9f9;border-radius:6px;padding:12px 16px;\">\n            <p style=\"margin:0;font-size:13px;color:#666666;line-height:1.8;font-family:Arial,Helvetica,sans-serif;\">\n              🥩 Default steak: <strong>Top Sirloin</strong>  |  🍗 Default chicken: <strong>Chicken Wrapped in Bacon</strong> 🔥<br>\n              🍪 Complimentary cookies are included too. Ask me how to get this.\n            </p>\n          </td>\n        </tr>\n      </table>\n\n      <p style=\"margin:0 0 8px;font-size:15px;line-height:1.7;font-family:Arial,Helvetica,sans-serif;color:#333333;\">\n        These are ballpark numbers so I can point you in the right direction without leading you the wrong way before we lock in your final guest count, menu, and service details 😊\n      </p>\n      <p style=\"margin:0 0 28px;font-size:15px;line-height:1.7;font-family:Arial,Helvetica,sans-serif;color:#333333;\">\n        <strong>Which option feels closer to what you want for the wedding?</strong>\n      </p>\n      <p style=\"margin:0 0 24px;font-size:15px;line-height:1.7;font-family:Arial,Helvetica,sans-serif;color:#333333;\">\n        If it helps, we could also jump on a quick call at 10:00 AM, 11:00 AM, or 1:00 PM.\n      </p>\n\n      <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"margin-bottom:28px;\">\n        <tr><td style=\"border-top:1px solid #eeeeee;font-size:0;line-height:0;\"> </td></tr>\n      </table>\n\n      <div style=\"margin:28px 0 0;padding:22px 24px;border-radius:24px;background:linear-gradient(180deg,#fff7ed 0%,#fff1f2 100%);border:1px solid #fed7aa;\">\n      <p style=\"margin:0 0 10px;font-size:24px;font-weight:800;color:#7c2d12;\">🍽️ Come Taste It First</p>\n      <p style=\"margin:0 0 14px;color:#7c2d12;\">If tasting makes more sense, I can save you a spot so you can experience the food before deciding from a distance.</p>\n      <p style=\"margin:0 0 14px;color:#431407;line-height:1.6;\">\n        <strong>Date:</strong> Sunday, May 3<br>\n        <strong>Location:</strong> 199 Main St, Fitchburg, MA 01420<br>\n        <strong>Time:</strong> 5:30 PM<br>\n        <strong>Code:</strong> ANDRE\n      </p>\n      <p style=\"margin:0 0 16px;color:#7c2d12;\">Seats are limited, so if you want in, reserve early.</p>\n      <div style=\"margin:0 0 16px;\">\n        <a href=\"https://drive.google.com/file/d/1V2glKcSbQUtDes3Cuk7Q4bFPiazU1NwT/view\" style=\"display:inline-block;padding:12px 18px;background:#f59e0b;color:#ffffff;text-decoration:none;border-radius:999px;font-weight:700;margin:0 10px 10px 0;\">Tasting Preview</a>\n        <a href=\"https://form.jotform.com/260145767354461\" style=\"display:inline-block;padding:12px 18px;background:#111827;color:#ffffff;text-decoration:none;border-radius:999px;font-weight:700;margin:0 10px 10px 0;\">Tasting Registration</a>\n      </div>\n      <p style=\"margin:0;color:#7c2d12;\">The last tasting was a blast, and I would rather let them experience it than guess from a distance.</p>\n    </div>\n\n      <p style=\"margin:0 0 4px;font-size:14px;color:#444444;font-family:Arial,Helvetica,sans-serif;\">Regards,</p>\n      <p style=\"margin:0 0 4px;font-size:15px;font-weight:bold;color:#1a1a1a;font-family:Arial,Helvetica,sans-serif;\">Andre Raw</p>\n      <p style=\"margin:0 0 4px;font-size:14px;color:#444444;font-family:Arial,Helvetica,sans-serif;\">Catering Event Coordinator</p>\n      <p style=\"margin:0 0 4px;font-size:14px;color:#444444;font-family:Arial,Helvetica,sans-serif;\">📲 C: (978) 235-3791  |  📲 W: (978) 381-1212</p>\n      <p style=\"margin:0;font-size:13px;font-family:Arial,Helvetica,sans-serif;\">\n        <a href=\"https://www.facebook.com/comeketocatering\" style=\"color:#ff4b00;text-decoration:none;\">Facebook</a>  | \n        <a href=\"https://instagram.com/comeketocatering\" style=\"color:#ff4b00;text-decoration:none;\">Instagram</a>  | \n        <a href=\"https://comeketocatering.com\" style=\"color:#ff4b00;text-decoration:none;\">Website</a>\n      </p>\n\n    </td>\n  </tr>\n\n  <tr>\n    <td bgcolor=\"#1a1a1a\" align=\"center\" style=\"background-color:#1a1a1a;padding:14px 32px;\">\n      <p style=\"margin:0;font-size:12px;color:#888888;font-family:Arial,Helvetica,sans-serif;\">\n        Comeketo Catering  |  199 Main St, Fitchburg, MA 01420  |  comeketocatering.com\n      </p>\n    </td>\n  </tr>\n\n</table>\n\n</td></tr>\n</table>\n\n</body>\n</html>"
