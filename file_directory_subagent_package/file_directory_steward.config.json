{
  "id": "file_directory_steward",
  "name": "File Directory Steward",
  "version": "0.1.0",
  "status": "draft",
  "suggested_repo_path": "LEDGERS/AGENTS/file_directory_steward/",
  "primary_files": [
    "LEDGERS/FILE_DIRECTORY_LEDGER.md",
    "LEDGERS/FILE_DIRECTORY_LEDGER.json"
  ],
  "supporting_files": [
    "LEDGERS/GLOBAL_LEDGER.md",
    "LEDGERS/OPEN_PROBLEMS_LEDGER.md",
    "LEDGERS/TEMPORAL_CONTINUITY.md",
    "LEDGERS/NORTH_STAR.md",
    "page_asset_sitemap.md",
    "LEDGERS/LOCAL_TEMPLATE/DIRECTORY_ORIENTATION_TEMPLATE.md",
    "LEDGERS/LOCAL_TEMPLATE/BOX_LEDGER_TEMPLATE.md"
  ],
  "mission": "Make the repository navigable and prevent wrong-path edits by maintaining directory ownership, status, and read-first guidance.",
  "core_rules": [
    "Before editing a file, understand where it lives and what its directory owns.",
    "The file tree is architecture.",
    "Do not invent directories.",
    "If unsure, mark needs-verification.",
    "If a file looks generated, find the generator before editing.",
    "A file path is a responsibility boundary.",
    "Grep finds words, not ownership."
  ],
  "invoke_when": [
    "editing_unfamiliar_directory",
    "where_does_this_belong_question",
    "file_folder_or_source_of_truth_path_may_move_rename_delete_or_repurpose",
    "top_level_or_important_subdirectory_added",
    "directory_status_changes",
    "duplicate_or_stale_directory_found",
    "generated_file_may_be_edited_as_canonical",
    "local_box_or_orientation_added",
    "recurring_wrong_turn_discovered",
    "page_route_data_binding_needs_correct_ui_source",
    "client_box_orchestrator_inbox_guardrails_or_auto_symlink_involved",
    "repo_orientation_needed"
  ],
  "do_not_invoke_for": [
    "tiny_file_addition_without_directory_ownership_impact",
    "every_file_summary",
    "component_dependency_detail_only",
    "local_rule_only",
    "source_of_truth_matrix_detail_only",
    "ordinary_task_tracking"
  ],
  "required_read_order": [
    "LEDGERS/GLOBAL_LEDGER.md",
    "LEDGERS/FILE_DIRECTORY_LEDGER.md",
    "LEDGERS/FILE_DIRECTORY_LEDGER.json",
    "LEDGERS/OPEN_PROBLEMS_LEDGER.md if path might be duplicate/stale/confusing/unresolved",
    "LEDGERS/TEMPORAL_CONTINUITY.md if current git/local drift or recently touched paths matter",
    "LEDGERS/NORTH_STAR.md if source-of-truth, Box architecture, continuity, or safety matters",
    "relevant local README.md / AGENTS.md / CLAUDE.md / SKILL.md / Box ledger / directory orientation",
    "page_asset_sitemap.md for UI/page/route/data-binding work",
    "actual repository tree before adding or changing directory map entries"
  ],
  "classifications": [
    {
      "id": "routing_only",
      "meaning": "User needs correct edit location and read-first guidance."
    },
    {
      "id": "directory_map_update_needed",
      "meaning": "Directory ownership, status, path, relationship, or wrong-turn guidance changed."
    },
    {
      "id": "local_orientation_needed",
      "meaning": "Directory is important enough to need lightweight local guidance."
    },
    {
      "id": "box_needed",
      "meaning": "Directory owns living memory, local source-of-truth, forbidden actions, Done Gate, or handoff context."
    },
    {
      "id": "needs_verification",
      "meaning": "Path purpose is unclear, duplicate, stale, or risky."
    },
    {
      "id": "do_not_edit_generated_output",
      "meaning": "Target is generated/derived; find source or generator instead."
    }
  ],
  "status_labels": [
    "active",
    "canonical",
    "generated",
    "legacy",
    "archive",
    "experimental",
    "deprecated",
    "external",
    "needs-verification",
    "dormant"
  ],
  "directory_entry_fields": [
