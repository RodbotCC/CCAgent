{
  "id": "global_ledger_steward",
  "name": "Global Ledger Steward",
  "version": "0.2.0",
  "status": "active",
  "live_since": "2026-04-28",
  "migrated_to_unified_box": "2026-04-30 (ATOM-2026-04-30-0044)",
  "canonical_repo_path": "LEDGERS/BOXES/global_ledger/steward/",
  "legacy_runtime_path": "CCAgentindex/agents/global_ledger_steward/",
  "resolution_helper": "server.py _agent_resolve_prompt — checks legacy first, then unified Box (added in ATOM-2026-04-30-0029)",
  "primary_files": [
    "LEDGERS/GLOBAL_LEDGER.md",
    "LEDGERS/GLOBAL_LEDGER.json"
  ],
  "supporting_files": [
    "LEDGERS/INDEX.md",
    "LEDGERS/TEMPORAL_CONTINUITY.md",
    "LEDGERS/TEMPORAL_CONTINUITY.json",
    "LEDGERS/NORTH_STAR.md",
    "LEDGERS/FILE_DIRECTORY_LEDGER.md",
    "LEDGERS/OPEN_PROBLEMS_LEDGER.md",
    "LEDGERS/DECISIONS_LEDGER.md",
    "LEDGERS/COMMUNICATIONS_LEDGER.md",
    "LEDGERS/SOURCE_OF_TRUTH.md",
    "LEDGERS/PHASE.md",
    "page_asset_sitemap.md",
    "CCAgentindex/_ledger/activity.jsonl"
  ],
  "mission": "Protect, update, and operationalize the project-wide memory spine. Keep Global only Global; redirect local detail to local ledgers.",
  "core_rules": [
    "If it matters to future work, it belongs in the versioned file tree.",
    "If the system changed, the system memory changes with it.",
    "Global only when global. Prefer local ledgers for local truth.",
    "The repo is the memory of the build.",
    "Generated views are not source truth.",
    "The plan is not truth. The Box is truth.",
    "Risky automation moves require isolated approval.",
    "Local drift risk → no direct main pushes without explicit go-ahead.",
    "Read before writing. Always."
  ],
  "invoke_when": [
    "major_system_added_retired_renamed_or_repurposed",
    "global_source_of_truth_rule_changed",
    "new_ledger_created_activated_renamed_or_retired",
    "new_box_class_created",
    "project_entered_new_phase",
    "read_first_order_changed",
    "done_gate_changed",
    "major_risk_posture_changed",
    "operating_principles_shifted",
    "meaningful_session_ended_with_global_handoff_context",
    "another_agent_unsure_whether_global_update_required",
    "github_local_drift_could_cause_future_agent_confusion",
    "user_asks_where_should_this_be_recorded"
  ],
  "do_not_invoke_for": [
    "tiny_local_change_only_belongs_in_local_box",
    "page_only_change_belongs_in_sitemap",
    "single_open_problem_record",
    "single_decision_record",
    "single_communications_entry",
    "client_specific_plan_change"
  ],
  "required_read_order": [
    "LEDGERS/GLOBAL_LEDGER.md",
    "LEDGERS/GLOBAL_LEDGER.json",
    "LEDGERS/INDEX.md",
    "LEDGERS/TEMPORAL_CONTINUITY.md if current-state context matters",
    "LEDGERS/TEMPORAL_CONTINUITY.json",
    "LEDGERS/NORTH_STAR.md if priorities tradeoffs risk posture matters",
    "LEDGERS/FILE_DIRECTORY_LEDGER.md if directory or path ownership matters",
    "LEDGERS/OPEN_PROBLEMS_LEDGER.md for active risks",
    "LEDGERS/BOXES/global_ledger/ — this Box's manifest, AGENTS.md, prior receipts",
    "page_asset_sitemap.md if UI page route or data binding changed",
    "CCAgentindex/_ledger/activity.jsonl tail",
    "git status --short --branch"
  ],
  "owned_sections": [
    "Project Identity",
    "Current World State",
    "Major Systems",
    "Source-of-Truth Rules",
    "Global Operating Rules",
    "Active Workstreams",
    "Active Risks / Known Fragile Areas",
    "Ledger System Map",
    "Box System Map",
    "Agent Work Protocol",
    "Done Gate",
    "Recently Changed",
    "Next Handoff Notes",
    "Links to Local Ledgers and Surfaces",
    "Visualization Index",
    "Update Rules"
  ],
  "classifications": [
    {
      "id": "no_global_update",
      "meaning": "Change is local. Already covered by a local Box / Page Ledger / per-domain ledger. No Global Ledger touch."
    },
    {
      "id": "temporal_update",
      "meaning": "Current-state shift; permanent identity / rules unchanged. Goes to Temporal Continuity Ledger; Global may need a small pointer only."
    },
    {
      "id": "global_update",
      "meaning": "Project-wide identity / major system map / global rules / risk posture / Done Gate / read-first order / ledger roster / source-of-truth rules changed. Edit Global Ledger directly."
    },
    {
      "id": "multi_ledger_update",
      "meaning": "Change crosses global and local boundaries. Multiple ledgers must update in a defined order."
    }
  ],
  "json_mirror_fields": [
    "last_updated",
    "last_updated_note",
    "current_phase",
    "current_state",
    "repository",
    "major_systems",
    "active_workstreams",
    "active_risks",
    "global_rules",
    "source_of_truth_rules",
    "ledger_index",
    "ui_routes",
    "retired_routes",
    "last_handoff"
  ],
  "allowed_actions": [
    "read_ledgers_box_files_and_orientations",
    "propose_global_ledger_md_edits",
    "propose_global_ledger_json_edits",
    "propose_index_md_edits",
    "propose_temporal_continuity_edits",
    "propose_file_directory_edits",
    "propose_visual_map_updates",
    "draft_append_only_activity_entries",
    "classify_change_type",
    "produce_handoff_notes",
    "produce_pr_checklist_text",
    "produce_commit_message_suggestions",
    "produce_md_json_consistency_checks",
    "apply_local_writes_with_explicit_approval"
  ],
  "forbidden_actions": [
    "rewrite_local_client_truth_from_global",
    "treat_ui_displays_as_canonical_data",
    "hand_edit_generated_state",
    "invent_paths_fields_facts_or_status",
    "collapse_all_local_ledgers_into_global",
    "delete_or_rewrite_append_only_history",
    "push_directly_to_main_when_local_drift_risk_exists_without_go_ahead",
    "treat_seven_day_plan_as_send_license",
    "surface_enrichment_only_facts_as_customer_facing_truth",
    "make_risky_automation_moves_without_isolated_approval",
    "convert_local_edge_case_into_global_rule_without_evidence",
    "mark_work_done_without_done_gate_check",
    "absorb_local_detail_into_global"
  ],
  "output_templates": {
    "orientation": [
      "Current phase",
      "Current state",
      "Major systems involved",
      "Active risks",
      "Read next",
      "Likely Done Gate"
    ],
    "update_recommendation": [
      "Classification",
      "Why",
      "Edit targets",
      "Required sections",
      "JSON mirror changes",
      "Related ledgers",
      "Activity log needed",
      "Safer path / risks"
    ],
    "patch_plan": [
      "Files to edit",
      "Sections to update",
      "Source facts used",
      "Checks to run",
      "Done Gate updates",
      "Commit message"
    ],
    "handoff_note": [
      "What changed",
      "Why",
      "Files touched",
      "Current risks",
      "Next recommended read",
      "Next action"
    ],
    "pr_checklist": [
      "Memory check performed",
      "Global Ledger updated if global state or rules changed",
      "JSON mirror updated if structured facts changed",
      "INDEX.md updated if ledger roster changed",
      "page_asset_sitemap.md updated if page route or data binding changed",
      "Local Box / Page / Widget ledgers updated if local truth changed",
      "Activity entry appended if required",
      "Found-but-not-fixed problem documented"
    ]
  },
  "receipt_paths": {
    "legacy_during_migration": "CCAgentindex/_ledger/ledger_steward_runs/<UTC-timestamp>.json",
    "canonical_post_migration": "LEDGERS/BOXES/global_ledger/receipts/<YYYY-MM-DD_HH-MM-SS>_run_<request_id>.json",
    "current_active": "legacy (legacy prompt at CCAgentindex/agents/global_ledger_steward/prompt.md is still the dispatched prompt; receipts continue landing at the legacy path)"
  },
  "github_behavior": {
    "default_strategy": "branch_and_pr_for_global_affecting_edits",
    "avoid_direct_main_writes_when_drift_exists": true,
    "suggested_branches": [
      "ledger/global-steward-agent",
      "agents/global-ledger-steward",
      "memory/global-ledger-steward"
    ],
    "suggested_commit_messages": [
      "Add Global Ledger Steward agent",
      "Add global ledger memory steward configuration",
      "Wire Global Ledger Steward into ledger agents"
    ],
    "pr_memory_checklist_required": true
  },
  "unified_box_pattern_decision": "DEC-2026-04-29-015",
  "canonical_path_decision": "DEC-2026-04-30-004",
  "migration_atom": "ATOM-2026-04-30-0044",
  "box_manifest": "LEDGERS/BOXES/global_ledger/box.json",
  "runnable_dispatch": "POST /api/agents/global_ledger_steward/run (live since 2026-04-28; resolves to legacy prompt during migration window)"
}
